DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Preferred for hosted apps (Supabase pooler):
# DATABASE_URL=postgresql://postgres.<project-ref>:<supabase-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
# Direct connection (when available for your project):
# DATABASE_URL=postgresql://postgres:<supabase-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.<project-ref>:<supabase-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DJANGO_TEST_USE_DATABASE_URL=false
DJANGO_TEST_DATABASE_URL=
TRIP_PLANNER_USE_EXTERNAL_GEOCODING=true
TRIP_PLANNER_USE_EXTERNAL_ROUTING=true
